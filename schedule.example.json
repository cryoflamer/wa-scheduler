{
  "timezone": "Europe/Kyiv",
  "notifications": {
    "version": 2,
    "whatsapp": {
      "enabled": false,
      "recipient": "${WA_RECIPIENT_SELF}",
      "events": [
        "job.completed",
        "job.failed",
        "job.partial",
        "job.manual.completed",
        "job.manual.failed",
        "job.manual.partial"
      ]
    },
    "ntfy": {
      "enabled": false,
      "server": "https://ntfy.sh",
      "topic": "${WA_NTFY_TOPIC}",
      "events": [
        "job.completed",
        "job.failed",
        "job.partial",
        "job.manual.completed",
        "job.manual.failed",
        "job.manual.partial",
        "whatsapp.disconnected"
      ]
    }
  },
  "jobs": [
    {
      "id": "monday-report",
      "schedule": "0 8 * * 1",
      "recipient": "${WA_RECIPIENT_SELF}",
      "message": "Доброго ранку. Надсилаю документи за понеділок.",
      "files": [
        {
          "path": "documents/test-document.txt",
          "caption": "тест"
        }
      ]
    }
  ]
}
