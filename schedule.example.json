{
  "timezone": "Europe/Kyiv",
  "notifications": {
    "version": 4,
    "whatsapp": {
      "enabled": false,
      "recipient": "${WA_RECIPIENT_SELF}",
      "events": [
        "job.completed",
        "job.failed",
        "job.partial",
        "job.catchup.started",
        "job.retry.scheduled",
        "job.recovered",
        "job.retry.exhausted",
        "job.manual.completed",
        "job.manual.failed",
        "job.manual.partial"
      ]
    },
    "ntfy": {
      "enabled": false,
      "server": "https://ntfy.sh",
      "topic": "${WA_NTFY_TOPIC}",
      "events": [
        "job.completed",
        "job.failed",
        "job.partial",
        "job.catchup.started",
        "job.retry.scheduled",
        "job.recovered",
        "job.retry.exhausted",
        "job.manual.completed",
        "job.manual.failed",
        "job.manual.partial",
        "whatsapp.disconnected"
      ]
    }
  },
  "jobs": []
}
