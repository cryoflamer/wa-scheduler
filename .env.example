WA_RECIPIENT_SELF=380XXXXXXXXX

# Local web interface authentication
WA_UI_AUTH_ENABLED=true
# WA_UI_PASSWORD is generated automatically on first start when authentication is enabled.

# Optional reliability settings
WA_ACTIVITY_RETENTION_DAYS=30
WA_STATE_RETENTION_DAYS=90
WA_MISSED_RUN_CATCHUP_HOURS=24
